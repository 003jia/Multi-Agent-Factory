{
  "name": "forge-town",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev:electron": "npm run build && npm run build:electron && electron dist/electron/main.js",
    "dist": "npm run build && npm run build:electron && electron-builder",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "start": "node dist/server/server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@vitejs/plugin-react": "^5.1.2",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "jsdom": "^28.0.0",
    "tsx": "^4.21.0",
    "vitest": "^4.0.16"
  },
  "build": {
    "appId": "com.jiayancheng.forgetown",
    "productName": "熔炼镇",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/icons/forge-town-house.png",
      "assets/icons/forge-town-house.icns",
      "package.json"
    ],
    "mac": {
      "icon": "assets/icons/forge-town-house.icns",
      "target": ["dmg"]
    }
  }
}
